{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "types": ["vitest/globals"],
    "skipLibCheck": true,
    "strict": false, 

    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

  
    "paths": {
      "@/*": ["./src/*"],
       
    }
  },
  "include": ["src/**/*"],
   "exclude": ["node_modules", "dist"]
}
